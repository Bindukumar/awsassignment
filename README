from azure vm
Testing my commit changes
testing 2
test 345678
pipeline {
    agent { label 'test' }

    environment {
        APP_REPO = 'https://github.com/your-user/your-repo.git'
        IMAGE_NAME = 'myphpapp'
        CONTAINER_NAME = 'myphpapp_container'
        PROD_SERVER = 'ubuntu@<PROD_VM_IP>'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'master', url: "${APP_REPO}"
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                  echo "Building Docker image..."
                  docker build -t ${IMAGE_NAME}:latest .
                '''
            }
        }

        stage('Deploy on Test Server') {
            steps {
                sh '''
                  echo "Stopping existing container if present..."
                  if [ "$(docker ps -aq -f name=${CONTAINER_NAME})" ]; then
                    docker rm -f ${CONTAINER_NAME} || true
                  fi

                  echo "Running new container..."
                  docker run -d --name ${CONTAINER_NAME} -p 80:80 ${IMAGE_NAME}:latest
                '''
            }
        }

        stage('Deploy to Production') {
            steps {
                sh '''
                  echo "Deploying to Production Server..."

                  ssh -o StrictHostKeyChecking=no ${PROD_SERVER} "
                    docker rm -f ${CONTAINER_NAME} || true
                    docker pull ${IMAGE_NAME}:latest || true
                    docker run -d --name ${CONTAINER_NAME} -p 80:80 ${IMAGE_NAME}:latest
                  "
                '''
            }
        }
    }

    post {
        failure {
            sh '''
              echo "Build failed. Cleaning up container on Test Server..."
              if [ "$(docker ps -q -f name=${CONTAINER_NAME})" ]; then
                docker rm -f ${CONTAINER_NAME} || true
              fi
            '''
        }
    }
}
